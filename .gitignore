# ===========================
# iOS (Xcode + SPM)
# ===========================

# Generated Xcode project (re-created by `xcodegen generate`).
HomesplitIOS.xcodeproj/
*.xcworkspace/

# Xcode user state & build output
xcuserdata/
*.xcuserstate
DerivedData/
build/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Per-developer xcconfig secrets (values are filled locally only)
HomesplitIOS/SupportingFiles/Config.Debug-Dev.xcconfig
HomesplitIOS/SupportingFiles/Config.Release-Dev.xcconfig
HomesplitIOS/SupportingFiles/Config.Release-Prod.xcconfig

# Provisioning + signing artifacts
*.mobileprovision
*.p8
*.p12
*.key
*.jks

# ===========================
# Legacy React Native (frozen; kept for behavioral spec reference)
# ===========================

# Dependencies
legacy/react-native/node_modules/
legacy/react-native/.pnp
legacy/react-native/.pnp.js

# Expo
legacy/react-native/.expo/
legacy/react-native/.expo-shared/
legacy/react-native/dist/
legacy/react-native/web-build/

# Expo-generated native projects
legacy/react-native/ios/
legacy/react-native/android/

# Env files (never commit)
legacy/react-native/.env
legacy/react-native/.env.local
legacy/react-native/.env.development
legacy/react-native/.env.production
legacy/react-native/.env.*.local
legacy/react-native/expo-env.d.ts

# Metro / Babel
legacy/react-native/.metro-health-check*

# Test output
legacy/react-native/coverage/

# ===========================
# Common
# ===========================

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Misc
*.orig.*
*.tsbuildinfo
npm-debug.*
yarn-debug.*
yarn-error.*

# Claude / workflow
.secrets/
